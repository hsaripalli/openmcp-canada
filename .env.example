# OpenMCP Anonymous Telemetry & Environment Configuration
# (Telemetry is ON by default using openMCP's anonymous collector. No PII or IP addresses are collected.)

# Set to true if you want to TURN OFF anonymous usage telemetry:
OPENMCP_TELEMETRY_DISABLED=false

# Optional: Uncomment below ONLY if you want to route telemetry to your OWN private Supabase database
# TELEMETRY_DB_URL=https://<your-project-ref>.supabase.co/rest/v1/telemetry_events
# TELEMETRY_DB_KEY=your-supabase-anon-key

